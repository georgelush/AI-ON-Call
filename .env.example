# Copy this file to .env and fill in your real values

# LLM
LLM_API_KEY=
LLM_PROXY=
# Example: LLM_PROXY=https://<your-tenant>.azurecontainerapps.io
LLM_MODEL=gpt-5.4-nano

# Available models on this proxy (as of 2026-03-31):
# | Model           | Category          | Best used for                          |
# |-----------------|-------------------|----------------------------------------|
# | gpt-5.4-nano    | Ultra cheap       | Default — classification, extraction, deterministic tasks |
# | gpt-5.4-mini    | Cheap + fast      | Light generation, simple responses     |
# | gpt-5-mini      | Cheap             | General light use                      |
# | gpt-5           | Standard          | General purpose                        |
# | gpt-5.1         | Standard+         | Chat agents, final responses           |
# | gpt-5.4         | Powerful          | Complex reasoning                      |
# | gpt-5.4-pro     | Most powerful     | Critical tasks, complex code           |
# | gpt-5-codex     | Code specialized  | Code generation and analysis           |
# | whisper         | Audio             | Speech to text                         |

# Langfuse (observabilitate / tracing)
LANGFUSE_PROXY=
# Example: LANGFUSE_PROXY=https://<your-tenant>.azurecontainerapps.io
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Twilio (voice calls — global credentials)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# PUBLIC_BASE_URL: VS Code port-forward URL or production URL (no trailing slash)
# Example: PUBLIC_BASE_URL=https://abc123-8080.app.github.dev
PUBLIC_BASE_URL=

# n8n (global instance — webhook path is per-agent, not stored here)
N8N_INSTANCE_URL=
N8N_API_KEY=

# Calls API — Bearer token required on POST /calls/outbound
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
CALLS_API_KEY=
